{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://ai-powered-website-phishing-detection.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}
